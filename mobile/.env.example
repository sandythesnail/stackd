# Copy to .env and fill in. All three are public/publishable keys (safe in the client
# bundle) and must point at the SAME Clerk instance + Supabase project as the web app,
# so mobile and web share user accounts and the user_progress row (cross-device sync).
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxx
EXPO_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx
